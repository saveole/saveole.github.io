<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>saveole's land</title>
    <link rel="icon" type="image/x-icon" href="./assets/img/favicons/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="./assets/img/favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="./assets/img/favicons/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="./assets/img/favicons/apple-touch-icon.png">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Source+Serif+Pro:ital,wght@0,400;0,700;1,400&display=swap">
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav class="navbar">
        <div class="container navbar-inner">
            <a href="index.html" class="logo">Blog.</a>
        </div>
    </nav>

    <main class="container">
        <header class="home-header">
            <p class="contrib-title">Token 不够？跑步来凑！</p>
            <div class="contrib-wrapper">
                <div class="contrib-months" id="contrib-months"></div>
                <div class="contrib-body">
                    <div class="contrib-days">
                        <span>Mon</span><span>Wed</span><span>Fri</span>
                    </div>
                    <div class="contrib-grid" id="contrib-grid"></div>
                </div>
            </div>
            <div class="contrib-legend">
                <div class="legend-group">
                    <span class="legend-label">🏃 Less</span>
                    <span class="legend-cell run-0"></span>
                    <span class="legend-cell run-1"></span>
                    <span class="legend-cell run-2"></span>
                    <span class="legend-cell run-3"></span>
                    <span class="legend-cell run-4"></span>
                    <span class="legend-cell run-5"></span>
                    <span class="legend-label">More</span>
                </div>
                <span class="legend-divider"></span>
                <div class="legend-group">
                    <span class="legend-label">💻 Less</span>
                    <span class="legend-cell token-0"></span>
                    <span class="legend-cell token-1"></span>
                    <span class="legend-cell token-2"></span>
                    <span class="legend-cell token-3"></span>
                    <span class="legend-cell token-4"></span>
                    <span class="legend-label">More</span>
                </div>
                <span class="legend-info-btn" tabindex="0">&#9432;</span>
                <div class="legend-info-panel">
                    <p><strong>Token 统计</strong>：仅统计 <strong>Claude Code</strong> 和 <strong>Hermes</strong> 的 token 消耗，不包含其他 AI 工具或平台。每个会话结束时，按 <code>session_id</code> 记录总消耗，归入<strong>会话结束当日</strong>（UTC）。</p>
                    <p><strong>跑步数据</strong>：来自 Garmin Connect CN，颜色基准 5km。</p>
                    <p><strong>可能的误差</strong>：</p>
                    <ul>
                        <li>跨天会话的所有 token 均计入结束日，开始日数据会偏低</li>
                        <li>使用 <code>--resume</code> 恢复会话后，transcript 为全量，可能导致旧 token 被重复计入新日期</li>
                    </ul>
                    <p class="legend-info-note">以上场景实际发生频率较低，不影响整体趋势参考。</p>
                </div>
            </div>
        </header>

        <section class="post-list">
            <% posts.forEach(post => { %>
                <div class="post-item" >
                    <time>
                        <%= post.date %>
                    </time>
                    <h2>
                        <a href="<%= post.url %>" style="text-decoration: none; color: var(--text-main);"><%= post.title %></a>
                    </h2>
                    <% if (post.subtitle) { %>
                        <p></p>
                    <% } %>
                </div>
            <% }) %>
        </section>
    </main>

    <footer class="container">
        <p>&copy; 2026 saveole.</p>
    </footer>

    <script>
    (function() {
        var data = <%- dailyData %>;
        if (!data || !data.days || data.days.length === 0) return;

        var tokenMap = {};
        var runningMap = {};
        data.days.forEach(function(d) {
            if (d.total_tokens) {
                var t = d.total_tokens;
                tokenMap[d.date] = t.input + t.output + t.cache_read + t.cache_creation;
            }
            if (d.running_km) runningMap[d.date] = d.running_km;
        });

        var today = new Date();
        var todayStr = today.getFullYear() + '-' +
            String(today.getMonth() + 1).padStart(2, '0') + '-' +
            String(today.getDate()).padStart(2, '0');

        var oneYearAgo = new Date(today);
        oneYearAgo.setFullYear(oneYearAgo.getFullYear() - 1);
        var dayOfWeek = oneYearAgo.getDay();
        var mondayOffset = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;
        var startDate = new Date(oneYearAgo);
        startDate.setDate(startDate.getDate() + mondayOffset);

        var weeks = [];
        var monthLabels = [];
        var lastMonth = -1;

        function toDateStr(d) {
            return d.getFullYear() + '-' +
                String(d.getMonth() + 1).padStart(2, '0') + '-' +
                String(d.getDate()).padStart(2, '0');
        }

        while (toDateStr(startDate) <= todayStr) {
            var week = [];
            for (var i = 0; i < 7; i++) {
                var dateStr = toDateStr(startDate);
                var month = startDate.getMonth();
                if (i === 0 && month !== lastMonth) {
                    monthLabels.push({
                        month: startDate.toLocaleString('zh-CN', { month: 'short' }),
                        weekIndex: weeks.length
                    });
                    lastMonth = month;
                }
                week.push({
                    date: dateStr,
                    tokens: tokenMap[dateStr] || 0,
                    running: runningMap[dateStr] || 0,
                    future: dateStr > todayStr
                });
                startDate.setDate(startDate.getDate() + 1);
            }
            weeks.push(week);
        }

        // Token color levels (quartile-based, all data)
        var tokenValues = Object.values(tokenMap).filter(function(v) { return v > 0; }).sort(function(a, b) { return a - b; });
        function getQuantile(arr, q) {
            var pos = (arr.length - 1) * q;
            var base = Math.floor(pos);
            var rest = pos - base;
            if (arr[base + 1] !== undefined) return arr[base] + rest * (arr[base + 1] - arr[base]);
            return arr[base];
        }
        var q1 = tokenValues.length > 0 ? getQuantile(tokenValues, 0.25) : 0;
        var q2 = tokenValues.length > 0 ? getQuantile(tokenValues, 0.5) : 0;
        var q3 = tokenValues.length > 0 ? getQuantile(tokenValues, 0.75) : 0;

        function getTokenLevel(v) {
            if (v === 0) return 0;
            if (v <= q1) return 1;
            if (v <= q2) return 2;
            if (v <= q3) return 3;
            return 4;
        }

        function getRunLevel(km) {
            if (km <= 0) return 0;
            if (km < 3) return 1;
            if (km < 5) return 2;
            if (km < 10) return 3;
            if (km < 15) return 4;
            return 5;
        }

        function formatRunning(km) {
            return km < 10 ? km.toFixed(1) : km.toFixed(0);
        }

        function formatTokens(n) {
            if (n >= 1e6) return (n / 1e6).toFixed(1) + ' M';
            if (n >= 1e3) {
                var k = n / 1e3;
                return (k >= 100 ? k.toFixed(0) : k.toFixed(1)) + ' K';
            }
            return String(n);
        }

        // Render month labels
        var monthsEl = document.getElementById('contrib-months');
        var monthHtml = '';
        var prevWeekIdx = -10;
        monthLabels.forEach(function(m) {
            var offset = m.weekIndex * 12;
            if (m.weekIndex > prevWeekIdx + 3) {
                monthHtml += '<span style="position:absolute;left:' + offset + 'px">' + m.month + '</span>';
                prevWeekIdx = m.weekIndex;
            }
        });
        monthsEl.innerHTML = monthHtml;

        // Render grid
        var totalWeeks = weeks.length;
        var edgeCount = 8;
        var gridEl = document.getElementById('contrib-grid');
        var gridHtml = '';

        weeks.forEach(function(week, wi) {
            week.forEach(function(day, di) {
                if (day.future) {
                    gridHtml += '<span class="contrib-cell" data-date="' + day.date + '" style="grid-column:' + (wi + 1) + ';grid-row:' + (di + 1) + '"></span>';
                    return;
                }

                var hasRun = day.running > 0;
                var hasTok = day.tokens > 0;
                var runLvl = getRunLevel(day.running);
                var tokLvl = getTokenLevel(day.tokens);

                var bg;
                if (hasRun && hasTok) {
                    bg = 'background:linear-gradient(90deg,var(--run-' + runLvl + ') 50%,var(--token-' + tokLvl + ') 50%)';
                } else if (hasRun) {
                    bg = 'background:var(--run-' + runLvl + ')';
                } else if (hasTok) {
                    bg = 'background:var(--token-' + tokLvl + ')';
                } else {
                    bg = 'background:var(--empty-cell)';
                }

                var cls = 'contrib-cell';
                if (wi < edgeCount) cls += ' edge-left';
                if (wi >= totalWeeks - edgeCount) cls += ' edge-right';

                var runStr = (hasRun ? formatRunning(day.running) : '0') + ' km';
                var tokStr = hasTok ? formatTokens(day.tokens) : '0 M';
                var tooltip = day.date + '\n🏃 ' + runStr + '\n💻 ' + tokStr;

                gridHtml += '<span class="' + cls + '" data-date="' + day.date + '" data-tooltip="' + tooltip + '" style="' + bg + ';grid-column:' + (wi + 1) + ';grid-row:' + (di + 1) + '"></span>';
            });
        });
        gridEl.innerHTML = gridHtml;
    })();
    </script>
</body>
</html>