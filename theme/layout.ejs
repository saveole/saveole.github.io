<!DOCTYPE html>
<html lang="zh-CN">
<head>
<%- include('_head', { title: title + ' | saveole\'s land' }) %>
</head>
<body>
<%- include('_nav') %>

    <main id="main" class="container">
        <article class="post">
            <header class="post-header">
                <time><%= date %></time>
                <h1><%= title %></h1>
                <% if (subtitle) { %>
                    <p class="subtitle"><%= subtitle %></p>
                <% } %>
                <div class="post-meta">
                    <% if (categories && categories.length) { %>
                        <span class="post-categories"><%= categories.join(' / ') %></span>
                    <% } %>
                    <% if (tags && tags.length) { %>
                        <span class="post-tags">
                            <% tags.forEach(function(tag, i) { %>
                                <a href="#" class="post-header-tag" data-tag="<%= tag %>"><%= tag %></a>
                            <% }) %>
                        </span>
                    <% } %>
                </div>
            </header>

            <section class="post-content">
                <%- content %>
            </section>

            <section class="giscus-container">
                <div class="giscus"></div>
            </section>
        </article>
    </main>

<%- include('_footer') %>

    <div class="tag-popup-overlay" id="tagPopupOverlay"></div>
    <div class="tag-popup" id="tagPopup" role="dialog" aria-modal="true" aria-labelledby="tagPopupName">
        <div class="tag-popup-header">
            <h3><span class="tag-popup-tag-name" id="tagPopupName"></span></h3>
            <button class="tag-popup-close" id="tagPopupClose">&times;</button>
        </div>
        <ul class="tag-popup-list" id="tagPopupList"></ul>
    </div>

    <script src="https://giscus.app/client.js"
            data-repo="saveole/saveole.github.io"
            data-repo-id="R_kgDOKgQ2Qw"
            data-category="General"
            data-category-id="DIC_kwDOKgQ2Q84Cfx18"
            data-mapping="pathname"
            data-strict="0"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="top"
            data-theme="preferred_color_scheme"
            data-lang="zh-CN"
            data-loading="lazy"
            crossorigin="anonymous"
            async>
    </script>

    <script>
    (function() {
        function esc(s) {
            var d = document.createElement('div');
            d.appendChild(document.createTextNode(s));
            return d.innerHTML;
        }

        var tagIndex = <%- tagIndex %>;
        var popup = document.getElementById('tagPopup');
        var overlay = document.getElementById('tagPopupOverlay');
        var popupName = document.getElementById('tagPopupName');
        var popupList = document.getElementById('tagPopupList');
        var popupClose = document.getElementById('tagPopupClose');
        var lastFocused = null;

        function getFocusable() {
            return popup.querySelectorAll('button, [href], [tabindex]:not([tabindex="-1"])');
        }

        function trapFocus(e) {
            var focusable = getFocusable();
            if (focusable.length === 0) return;
            var first = focusable[0];
            var last = focusable[focusable.length - 1];
            if (e.key === 'Tab') {
                if (e.shiftKey) {
                    if (document.activeElement === first) { e.preventDefault(); last.focus(); }
                } else {
                    if (document.activeElement === last) { e.preventDefault(); first.focus(); }
                }
            }
        }

        function closePopup() {
            popup.classList.remove('active');
            overlay.classList.remove('active');
            document.removeEventListener('keydown', trapFocus);
            if (lastFocused) lastFocused.focus();
        }

        function openPopup(tag) {
            lastFocused = document.activeElement;
            var posts = tagIndex[tag] || [];
            popupName.textContent = '#' + tag;
            popupList.innerHTML = '';
            if (posts.length === 0) {
                popupList.innerHTML = '<li class="tag-popup-empty">暂无相关文章</li>';
            } else {
                posts.sort(function(a, b) { return a.date > b.date ? -1 : 1; });
                posts.forEach(function(p) {
                    var li = document.createElement('li');
                    var a = document.createElement('a');
                    a.href = p.url;
                    a.innerHTML = '<span class="popup-post-title">' + esc(p.title) + '</span><span class="popup-post-date">' + esc(p.date) + '</span>';
                    li.appendChild(a);
                    popupList.appendChild(li);
                });
            }
            popup.classList.add('active');
            overlay.classList.add('active');
            popupClose.focus();
            document.addEventListener('keydown', trapFocus);
        }

        overlay.addEventListener('click', closePopup);
        popupClose.addEventListener('click', closePopup);
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && popup.classList.contains('active')) closePopup();
        });

        document.addEventListener('click', function(e) {
            var el = e.target.closest('.inline-tag, .post-header-tag');
            if (el) {
                e.preventDefault();
                openPopup(el.getAttribute('data-tag'));
            }
        });
    })();
    </script>
</body>
</html>
