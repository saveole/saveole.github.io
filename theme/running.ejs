<!DOCTYPE html>
<html lang="zh-CN">
<head>
<%- include('_head', { title: 'Running | saveole\'s land', extraPreconnect: '<link rel="preconnect" href="https://cdn.jsdelivr.net">', extraHead: '<script src="https://cdn.jsdelivr.net/npm/chart.js" async></script>' }) %>
</head>
<body>
<%- include('_nav', { activeNav: 'running' }) %>

    <main id="main" class="container">
        <header class="running-header">
            <div class="running-header-row">
                <div class="chart-tabs" id="chartTabs">
                    <button class="chart-tab active" data-tab="tracks">轨迹</button>
                    <button class="chart-tab" data-tab="charts">图表</button>
                </div>
            </div>
        </header>

        <div class="dashboard-card" id="tracksPanel">
            <div class="tracks-grid" id="tracksGrid"></div>
        </div>

        <div class="dashboard-card" id="chartsPanel" style="display:none;">
            <div class="chart-row">
                <canvas id="bodyChart"></canvas>
            </div>
            <div class="chart-divider"></div>
            <div class="chart-row">
                <canvas id="runningChart"></canvas>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="list-header">
                <div class="year-tabs" id="yearTabs"></div>
            </div>
            <div class="table-wrapper">
                <table class="activity-table">
                    <thead>
                        <tr>
                            <th class="text-left">活动</th>
                            <th class="text-right">KM</th>
                            <th class="text-right">Pace</th>
                            <th class="text-right">BPM</th>
                            <th class="text-right">Time</th>
                            <th class="text-right">Date</th>
                        </tr>
                    </thead>
                    <tbody id="activityListBody"></tbody>
                </table>
            </div>
        </div>
    </main>

<%- include('_footer') %>
    <script>
    (function() {
        function esc(s) {
            var d = document.createElement('div');
            d.appendChild(document.createTextNode(s));
            return d.innerHTML;
        }

        var timeline = <%- timelineJSON %>;
        var bodyRecords = <%- bodyJSON %>;
        var activityRecords = <%- activitiesJSON %>;
        var trackRecords = <%- tracksJSON %>;

        // Read CSS variables early (needed by renderTracks)
        var cs = getComputedStyle(document.documentElement);
        var muted = cs.getPropertyValue('--text-muted').trim();
        var borderClr = cs.getPropertyValue('--border-color').trim();
        var weightClr = cs.getPropertyValue('--chart-weight').trim();
        var fatClr = cs.getPropertyValue('--chart-fat').trim();
        var hrClr = cs.getPropertyValue('--chart-hr').trim();
        var distClr = cs.getPropertyValue('--chart-distance').trim();
        var distHoverClr = cs.getPropertyValue('--chart-distance-hover').trim();
        var trackClr = cs.getPropertyValue('--track-stroke').trim();

        // ---- Chart/Tracks tab switching ----
        (function() {
            var tabs = document.querySelectorAll('.chart-tab');
            var chartsPanel = document.getElementById('chartsPanel');
            var tracksPanel = document.getElementById('tracksPanel');
            renderTracks();
            tabs.forEach(function(tab) {
                tab.addEventListener('click', function() {
                    tabs.forEach(function(t) { t.classList.remove('active'); });
                    tab.classList.add('active');
                    if (tab.dataset.tab === 'charts') {
                        chartsPanel.style.display = '';
                        tracksPanel.style.display = 'none';
                    } else {
                        chartsPanel.style.display = 'none';
                        tracksPanel.style.display = '';
                        renderTracks();
                    }
                });
            });
        })();

        // ---- Polyline decoder (Google encoded polyline) ----
        function decodePolyline(encoded) {
            var points = [];
            var index = 0, lat = 0, lng = 0;
            while (index < encoded.length) {
                var b, shift = 0, result = 0;
                do {
                    b = encoded.charCodeAt(index++) - 63;
                    result |= (b & 0x1f) << shift;
                    shift += 5;
                } while (b >= 0x20);
                lat += ((result & 1) ? ~(result >> 1) : (result >> 1));
                shift = 0; result = 0;
                do {
                    b = encoded.charCodeAt(index++) - 63;
                    result |= (b & 0x1f) << shift;
                    shift += 5;
                } while (b >= 0x20);
                lng += ((result & 1) ? ~(result >> 1) : (result >> 1));
                points.push([lat / 1e5, lng / 1e5]);
            }
            return points;
        }

        // ---- Track similarity (Grid Jaccard) ----
        function downsampleTrack(points, n) {
            if (points.length <= n) return points;
            var step = points.length / n;
            var result = [];
            for (var i = 0; i < n; i++) {
                result.push(points[Math.floor(i * step)]);
            }
            return result;
        }

        function computeSimilarityMatrix(tracks) {
            var cellSize = 0.0004;   // ~44 meters per grid cell
            var threshold = 0.20;
            var sampleCount = 80;

            // Build grid cell sets for each track
            var gridSets = tracks.map(function(track) {
                var pts = downsampleTrack(decodePolyline(track.summary_polyline), sampleCount);
                var cells = {};
                for (var i = 0; i < pts.length; i++) {
                    var key = Math.round(pts[i][0] / cellSize) + ',' + Math.round(pts[i][1] / cellSize);
                    cells[key] = true;
                }
                return cells;
            });

            // Compute pairwise Jaccard similarity
            var result = [];
            for (var i = 0; i < tracks.length; i++) result[i] = [];

            for (var i = 0; i < tracks.length; i++) {
                for (var j = i + 1; j < tracks.length; j++) {
                    var inter = 0, union = 0;
                    var a = gridSets[i], b = gridSets[j];
                    for (var k in a) { if (b[k]) inter++; union++; }
                    for (var k in b) { if (!a[k]) union++; }
                    var score = union > 0 ? inter / union : 0;
                    if (score >= threshold) {
                        result[i].push({ index: j, score: score });
                        result[j].push({ index: i, score: score });
                    }
                }
            }
            // Sort by score descending
            for (var i = 0; i < result.length; i++) {
                result[i].sort(function(a, b) { return b.score - a.score; });
            }
            return result;
        }

        // ---- SVG rendering helpers ----
        function buildTrackSVG(track, w, h) {
            var points = decodePolyline(track.summary_polyline);
            if (points.length < 2) return null;

            var minLat = Infinity, maxLat = -Infinity, minLng = Infinity, maxLng = -Infinity;
            points.forEach(function(p) {
                if (p[0] < minLat) minLat = p[0];
                if (p[0] > maxLat) maxLat = p[0];
                if (p[1] < minLng) minLng = p[1];
                if (p[1] > maxLng) maxLng = p[1];
            });
            var rangeLat = maxLat - minLat || 0.001;
            var rangeLng = maxLng - minLng || 0.001;
            var pad = 5;

            var coords = points.map(function(p) {
                var x = pad + ((p[1] - minLng) / rangeLng) * (w - pad * 2);
                var y = pad + ((maxLat - p[0]) / rangeLat) * (h - pad * 2);
                return x.toFixed(1) + ',' + y.toFixed(1);
            }).join(' ');

            return '<svg viewBox="0 0 ' + w + ' ' + h + '" class="track-svg" preserveAspectRatio="xMidYMid meet">' +
                '<polyline points="' + coords + '" fill="none" stroke="' + trackClr + '" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>' +
            '</svg>';
        }

        // ---- Similar tracks overlay ----
        function showSimilarPanel(trackIdx, tracks, simMatrix) {
            var track = tracks[trackIdx];
            var similar = simMatrix[trackIdx] || [];

            var overlay = document.createElement('div');
            overlay.className = 'similar-overlay';

            var panel = document.createElement('div');
            panel.className = 'similar-panel';
            panel.setAttribute('role', 'dialog');
            panel.setAttribute('aria-modal', 'true');

            // Header
            var header = document.createElement('div');
            header.className = 'similar-panel-header';
            header.innerHTML =
                '<span class="similar-panel-title">' + esc(track.date) + ' · ' + track.distance_km.toFixed(1) + ' km</span>' +
                '<button class="similar-panel-close">关闭</button>';
            panel.appendChild(header);

            // Selected track SVG
            var selectedWrap = document.createElement('div');
            selectedWrap.className = 'similar-panel-selected';
            selectedWrap.innerHTML = buildTrackSVG(track, 400, 180) +
                '<div class="track-info">' +
                    '<span class="track-date">' + esc(track.date) + '</span>' +
                    '<span class="track-stat">' + track.distance_km.toFixed(1) + ' km · ' + esc(track.pace) + '</span>' +
                '</div>';
            panel.appendChild(selectedWrap);

            // Similar tracks row
            if (similar.length > 0) {
                var matchesWrap = document.createElement('div');
                matchesWrap.className = 'similar-panel-matches';

                similar.forEach(function(match) {
                    var t = tracks[match.index];
                    var pct = Math.round(match.score * 100);
                    var thumb = document.createElement('div');
                    thumb.className = 'similar-track-thumb';
                    thumb.innerHTML = buildTrackSVG(t, 130, 90) +
                        '<div class="track-info">' +
                            '<span class="track-date">' + esc(t.date) + '</span>' +
                            '<span class="track-stat">' + pct + '% 相似</span>' +
                        '</div>';
                    matchesWrap.appendChild(thumb);
                });

                panel.appendChild(matchesWrap);
            }

            overlay.appendChild(panel);
            document.body.appendChild(overlay);

            // Close handlers
            function close() {
                document.body.removeChild(overlay);
            }
            header.querySelector('.similar-panel-close').onclick = close;
            overlay.addEventListener('click', function(e) {
                if (e.target === overlay) close();
            });
            document.addEventListener('keydown', function esc(e) {
                if (e.key === 'Escape') { close(); document.removeEventListener('keydown', esc); }
            });
        }

        function renderTracks() {
            var grid = document.getElementById('tracksGrid');
            if (grid.children.length > 0) return; // already rendered

            if (trackRecords.length === 0) {
                grid.innerHTML = '<p class="tracks-empty">暂无轨迹数据。同步活动数据后，户外跑步的轨迹将展示在这里。</p>';
                return;
            }

            var displayTracks = trackRecords.slice(0, 9);
            var cards = [];

            displayTracks.forEach(function(track, idx) {
                var svgHtml = buildTrackSVG(track, 200, 200);
                if (!svgHtml) return;

                var card = document.createElement('div');
                card.className = 'track-card';
                card.innerHTML =
                    '<div class="track-svg-wrap">' +
                        svgHtml +
                    '</div>' +
                    '<div class="track-info">' +
                        '<span class="track-date">' + esc(track.date) + '</span>' +
                        '<span class="track-stat">' + track.distance_km.toFixed(1) + ' km · ' + esc(track.pace) + '</span>' +
                    '</div>';
                grid.appendChild(card);
                cards.push({ el: card, idx: idx });
            });

            // Compute similarity and add badges
            if (displayTracks.length >= 2) {
                var simMatrix = computeSimilarityMatrix(displayTracks);
                cards.forEach(function(item) {
                    var similar = simMatrix[item.idx];
                    if (similar && similar.length > 0) {
                        item.el.classList.add('has-similar');
                        var badge = document.createElement('span');
                        badge.className = 'track-similar-badge';
                        badge.textContent = similar.length;
                        item.el.querySelector('.track-svg-wrap').appendChild(badge);

                        (function(trackIdx) {
                            item.el.addEventListener('click', function() {
                                showSimilarPanel(trackIdx, displayTracks, simMatrix);
                            });
                        })(item.idx);
                    }
                });
            }
        }

        var weightData = Array(timeline.length).fill(null);
        var fatData = Array(timeline.length).fill(null);
        var distanceData = Array(timeline.length).fill(null);
        var hrData = Array(timeline.length).fill(null);

        bodyRecords.forEach(function(d) {
            var idx = timeline.indexOf(d.date);
            if (idx !== -1) { weightData[idx] = d.weight_kg; fatData[idx] = d.body_fat_pct; }
        });

        activityRecords.forEach(function(a) {
            var idx = timeline.indexOf(a.date);
            if (idx !== -1) { distanceData[idx] = a.distance_km; hrData[idx] = a.avg_hr; }
        });

        // Render activity list
        var listBody = document.getElementById('activityListBody');

        // Extract years and build tabs
        var yearSet = {};
        activityRecords.forEach(function(a) {
            yearSet[a.date.slice(0, 4)] = true;
        });
        var years = Object.keys(yearSet).sort().reverse();
        var currentYear = String(new Date().getFullYear());
        var activeYear = years.indexOf(currentYear) !== -1 ? currentYear : years[0];

        var tabsEl = document.getElementById('yearTabs');
        years.forEach(function(y) {
            var btn = document.createElement('button');
            btn.textContent = y;
            btn.className = 'year-tab' + (y === activeYear ? ' active' : '');
            btn.onclick = function() {
                activeYear = y;
                var tabs = tabsEl.querySelectorAll('.year-tab');
                for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
                btn.classList.add('active');
                renderList(y);
            };
            tabsEl.appendChild(btn);
        });

        function renderList(year) {
            var html = '';
            activityRecords.forEach(function(a) {
                if (a.date.slice(0, 4) !== year) return;
                var hour = a.start_time ? parseInt(a.start_time.split(':')[0], 10) : 12;
                var isTreadmill = a.type === 'treadmill_running';
                var period;
                if (hour >= 5 && hour < 9) period = '清晨';
                else if (hour >= 9 && hour < 12) period = '上午';
                else if (hour >= 12 && hour < 18) period = '下午';
                else period = '夜晚';
                var label = period + (isTreadmill ? '跑步机' : '户外');

                var dateDisplay = a.date + ' ' + (a.start_time || '00:00:00');

                html += '<tr>' +
                    '<td class="text-left run-title">' + esc(label) + '</td>' +
                    '<td class="text-right km-val">' + a.distance_km.toFixed(2) + '</td>' +
                    '<td class="text-right">' + esc(a.pace) + '</td>' +
                    '<td class="text-right">' + (a.avg_hr != null ? a.avg_hr : '') + '</td>' +
                    '<td class="text-right">' + esc(a.duration) + '</td>' +
                    '<td class="text-right">' + esc(dateDisplay) + '</td>' +
                    '</tr>';
            });
            listBody.innerHTML = html;
        }

        renderList(activeYear);

        // Wait for Chart.js to load (async script), then initialize charts
        function initCharts() {
            if (typeof Chart === 'undefined') {
                setTimeout(initCharts, 50);
                return;
            }
            var commonScalesX = {
            grid: { display: false },
            ticks: { color: muted, font: { size: 10, family: 'Inter', weight: '300' }, maxTicksLimit: 8, maxRotation: 0 },
            border: { display: false }
        };

        var chartBody = new Chart(document.getElementById('bodyChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: timeline,
                datasets: [
                    { label: '体重', data: weightData, borderColor: weightClr, backgroundColor: 'transparent', borderWidth: 2, pointRadius: 1.5, spanGaps: true, tension: 0.4, yAxisID: 'yW' },
                    { label: '体脂', data: fatData, borderColor: fatClr, backgroundColor: 'transparent', borderWidth: 2, pointRadius: 1.5, spanGaps: true, tension: 0.4, yAxisID: 'yF' }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'top', align: 'end', labels: { boxWidth: 6, usePointStyle: true, font: { size: 10, family: 'Inter' } } } },
                scales: {
                    x: Object.assign({}, commonScalesX, { ticks: Object.assign({}, commonScalesX.ticks, { display: false }) }),
                    yW: { type: 'linear', position: 'left', suggestedMin: 70, suggestedMax: 85, ticks: { color: muted, font: { size: 10, family: 'Inter' }, stepSize: 5, callback: function(v) { return v + ' kg'; } }, grid: { color: borderClr }, border: { display: false } },
                    yF: { type: 'linear', position: 'right', suggestedMin: 15, suggestedMax: 35, ticks: { color: muted, font: { size: 10, family: 'Inter' }, stepSize: 5, callback: function(v) { return v + ' %'; } }, grid: { display: false }, border: { display: false } }
                }
            }
        });

        var chartRunning = new Chart(document.getElementById('runningChart').getContext('2d'), {
            data: {
                labels: timeline,
                datasets: [
                    { type: 'bar', label: '距离', data: distanceData, backgroundColor: distClr, hoverBackgroundColor: distHoverClr, barThickness: 6, yAxisID: 'yDistance' },
                    { type: 'line', label: '心率', data: hrData, borderColor: hrClr, backgroundColor: 'transparent', borderWidth: 2, pointRadius: 1.5, spanGaps: true, tension: 0.4, yAxisID: 'yH' }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'top', align: 'end', labels: { boxWidth: 6, usePointStyle: true, font: { size: 10, family: 'Inter' } } }, tooltip: { usePointStyle: true } },
                scales: {
                    x: commonScalesX,
                    yDistance: { type: 'linear', position: 'left', suggestedMin: 0, suggestedMax: 20, ticks: { color: muted, font: { size: 10, family: 'Inter' }, stepSize: 5, callback: function(v) { return v + ' km'; } }, grid: { color: borderClr }, border: { display: false } },
                    yH: { type: 'linear', position: 'right', suggestedMin: 100, suggestedMax: 180, ticks: { color: muted, font: { size: 10, family: 'Inter' }, stepSize: 20, callback: function(v) { return v + ' bpm'; } }, grid: { display: false }, border: { display: false } }
                }
            }
        });

        // Dual chart hover sync
        function triggerHover(targetChart, event) {
            var points = targetChart.getElementsAtEventForMode(event, 'index', { intersect: false }, true);
            if (points.length > 0) {
                targetChart.setActiveElements(points);
                targetChart.tooltip.setActiveElements(points, { x: event.x, y: event.y });
                targetChart.update('none');
            }
        }

        document.getElementById('bodyChart').addEventListener('mousemove', function(e) {
            triggerHover(chartRunning, Chart.helpers.getRelativePosition(e, chartBody));
        });
        document.getElementById('runningChart').addEventListener('mousemove', function(e) {
            triggerHover(chartBody, Chart.helpers.getRelativePosition(e, chartRunning));
        });
        } // end initCharts

        initCharts();
    })();
    </script>
</body>
</html>